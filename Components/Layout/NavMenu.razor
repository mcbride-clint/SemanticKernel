@inject IJSRuntime JS

<nav class="nav-menu">
    <div class="nav-brand">Agent Chat</div>
    <ul>
        <li><NavLink href="" Match="NavLinkMatch.All">Chat</NavLink></li>
        <li><NavLink href="debug">Debug Agents</NavLink></li>
    </ul>
    <button class="dark-mode-btn small-btn" @onclick="ToggleDarkMode" title="Toggle dark mode">
        @(_isDark ? "☀" : "🌙")
    </button>
</nav>

@code {
    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "theme");
            _isDark = stored == "dark";
            await ApplyThemeAsync();
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("localStorage.setItem", "theme", _isDark ? "dark" : "light");
        await ApplyThemeAsync();
    }

    private async Task ApplyThemeAsync()
    {
        if (_isDark)
            await JS.InvokeVoidAsync("eval", "document.documentElement.classList.add('dark')");
        else
            await JS.InvokeVoidAsync("eval", "document.documentElement.classList.remove('dark')");
    }
}
