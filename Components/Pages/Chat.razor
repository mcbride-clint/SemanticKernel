@page "/"
@using BlazorAgentChat.Abstractions
@using BlazorAgentChat.Abstractions.Models
@using BlazorAgentChat.Models
@using Markdig
@using System.Text
@using System.Text.Json
@inject IOrchestrationService Orchestrator
@inject IAgentRegistry Registry
@inject IAttachmentProcessor AttachmentProcessor
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Agent Chat</PageTitle>

<div class="chat-container">

    <!-- ── Agent Selection Panel ──────────────────────────────────── -->
    <div class="agent-panel-toggle">
        <button class="agent-toggle-btn" @onclick="ToggleAgentPanel">
            🤖 Agents (@_enabledIds.Count/@_allAgents.Count enabled)
            <span class="toggle-arrow">@(_showAgentPanel ? "▲" : "▼")</span>
        </button>
    </div>

    @if (_showAgentPanel)
    {
        <div class="agent-panel">
            <div class="agent-panel-header">
                <span>Select which agents can answer your questions</span>
                <span class="agent-panel-actions">
                    <button class="small-btn" @onclick="EnableAll">All</button>
                    <button class="small-btn" @onclick="DisableAll">None</button>
                </span>
            </div>
            @if (_allAgents.Count > 5)
            {
                <input type="search"
                       class="agent-search-input"
                       placeholder="Filter agents…"
                       @bind="_agentSearchText"
                       @bind:event="oninput" />
            }
            @foreach (var group in FilteredAgents.GroupBy(a => a.SourceType))
            {
                <div class="agent-group">
                    <div class="agent-group-label">@group.Key.ToUpperInvariant()</div>
                    @foreach (var agent in group)
                    {
                        <label class="agent-checkbox-row">
                            <input type="checkbox"
                                   checked="@_enabledIds.Contains(agent.Id)"
                                   @onchange="e => ToggleAgent(agent.Id, (bool)e.Value!)" />
                            <span class="agent-checkbox-name">@agent.Name</span>
                            <span class="agent-checkbox-desc">@agent.Description</span>
                        </label>
                    }
                </div>
            }
            @if (!_allAgents.Any())
            {
                <p class="agent-panel-empty">No agents loaded. Check Data/ directory and logs.</p>
            }
        </div>
    }

    <!-- ── Chat History ───────────────────────────────────────────── -->
    <div class="chat-history" @ref="_historyRef">
        @foreach (var entry in _history)
        {
            <div class="chat-entry @entry.Role.ToString().ToLower()" id="entry-@entry.Id">
                <span class="role-label">@entry.Role</span>

                @if (entry.Role == ChatEntry.ChatRole.Assistant)
                {
                    <div class="content markdown-content">
                        @((MarkupString)Markdown.ToHtml(entry.Content ?? "", _mdPipeline))
                    </div>
                    <div class="entry-actions">
                        @if (entry.AgentInfo is not null)
                        {
                            <span class="agent-disclosure">@entry.AgentInfo</span>
                        }
                        <button class="copy-btn"
                                title="Copy to clipboard"
                                @onclick="() => CopyToClipboardAsync(entry)">
                            @(_copiedId == entry.Id ? "✓ Copied" : "⎘ Copy")
                        </button>
                    </div>
                }
                else
                {
                    <span class="content">@entry.Content</span>
                    @if (entry.AttachmentName is not null)
                    {
                        <span class="attachment-badge">📎 @entry.AttachmentName</span>
                    }
                }

                <span class="timestamp">@entry.Timestamp.ToString("HH:mm:ss")</span>
            </div>
        }

        @if (_isThinking)
        {
            <div class="chat-entry assistant thinking">
                <span class="spinner"></span>
                @if (_isAnalyzingAttachment)
                {
                    <span>Analyzing attachment…</span>
                }
                else
                {
                    <span>@(_progressMessage ?? "Thinking…")</span>
                }
            </div>
        }
    </div>

    <!-- ── Metadata Bar ───────────────────────────────────────────── -->
    @if (Orchestrator.LastMetadata is { } meta)
    {
        <div class="metadata-bar">
            @{
                var agentSummary = string.Join(", ", meta.SelectedAgents
                    .Select(s => $"{ResolveAgentName(s.AgentId)} ({s.Confidence:P0})"));
            }
            Consulted: @agentSummary |
            Elapsed: @meta.TotalElapsed.TotalSeconds.ToString("F1")s |
            Id: @meta.CorrelationId
        </div>
    }

    <!-- ── Attachment Preview ─────────────────────────────────────── -->
    @if (_pendingAttachmentName is not null)
    {
        <div class="attachment-preview">
            @if (_processedAttachment?.IsImage == true)
            {
                var dataUri = $"data:{_processedAttachment.ContentType};base64,{Convert.ToBase64String(_processedAttachment.Bytes)}";
                <img src="@dataUri" class="attachment-thumbnail" alt="attachment preview" />
            }
            else
            {
                <span class="attachment-preview-icon">📎</span>
            }
            <span class="attachment-preview-name">@_pendingAttachmentName</span>
            <button class="attachment-remove-btn" @onclick="RemoveAttachment" title="Remove attachment">✕</button>
        </div>
    }

    <!-- ── Input Row ──────────────────────────────────────────────── -->
    <div class="chat-input-row">
        <label class="attach-btn" title="Attach file (PDF, image, or text)">
            📎
            <InputFile OnChange="HandleFileSelected" accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.txt,.csv,.md" disabled="@_isThinking" />
        </label>
        <textarea @bind="_inputText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="Ask a question… (Enter to send, Shift+Enter for new line)"
                  rows="3"
                  disabled="@_isThinking" />
        @if (_isThinking)
        {
            <button class="stop-btn" @onclick="StopStreaming" title="Stop generating">■ Stop</button>
        }
        else
        {
            <button @onclick="SendAsync" disabled="@(_enabledIds.Count == 0)">Send</button>
        }
    </div>

    <!-- ── Toolbar (Clear + Export) ───────────────────────────────── -->
    <div class="chat-toolbar">
        <button class="small-btn toolbar-btn"
                @onclick="() => ClearConversation()"
                disabled="@(_history.Count == 0)"
                title="Clear conversation history">
            🗑 Clear
        </button>
        <button class="small-btn toolbar-btn"
                @onclick='() => ExportConversationAsync("md")'
                disabled="@(_history.Count == 0)"
                title="Download conversation as Markdown">
            ↓ MD
        </button>
        <button class="small-btn toolbar-btn"
                @onclick='() => ExportConversationAsync("json")'
                disabled="@(_history.Count == 0)"
                title="Download conversation as JSON">
            ↓ JSON
        </button>
    </div>

    @if (_enabledIds.Count == 0)
    {
        <p class="no-agents-warning">Enable at least one agent to send a message.</p>
    }

</div>

@code {
    // ── Markdown pipeline (built once) ──────────────────────────────
    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    // ── Chat state ───────────────────────────────────────────────────
    private readonly List<ChatEntry> _history = [];
    private string  _inputText  = string.Empty;
    private bool    _isThinking;
    private bool    _isAnalyzingAttachment;
    private string? _progressMessage;
    private ElementReference _historyRef;
    private CancellationTokenSource? _cts;
    private Guid? _copiedId;
    private bool  _shouldScrollToBottom;

    // ── Agent selection state ────────────────────────────────────────
    private IReadOnlyList<AgentInfo> _allAgents     = [];
    private HashSet<string>          _enabledIds    = [];
    private bool                     _showAgentPanel;
    private string                   _agentSearchText = string.Empty;

    private IEnumerable<AgentInfo> FilteredAgents =>
        string.IsNullOrWhiteSpace(_agentSearchText)
            ? _allAgents
            : _allAgents.Where(a =>
                a.Name.Contains(_agentSearchText, StringComparison.OrdinalIgnoreCase) ||
                a.Description.Contains(_agentSearchText, StringComparison.OrdinalIgnoreCase));

    // ── Attachment state ─────────────────────────────────────────────
    private AttachedDocument? _processedAttachment;
    private string?           _pendingAttachmentName;

    protected override void OnInitialized()
    {
        _allAgents  = Registry.GetAll();
        _enabledIds = _allAgents.Select(a => a.Id).ToHashSet();

        // Subscribe to pipeline stage progress events (ME-4)
        Orchestrator.OnProgressChanged += HandleProgressChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // LF-3: Restore conversation history from LocalStorage on page load
            await RestoreHistoryFromStorageAsync();
        }

        // QW-3: Auto-scroll to latest message after each streaming token
        if (_shouldScrollToBottom)
        {
            _shouldScrollToBottom = false;
            await JS.InvokeVoidAsync("eval",
                "document.querySelector('.chat-history')?.scrollTo({top: 999999, behavior: 'smooth'})");
        }
    }

    // ── LocalStorage persistence (LF-3) ─────────────────────────────
    private const string HistoryStorageKey = "blazorchat_history_v1";
    private const string HistoryTimestampKey = "blazorchat_history_ts";
    private static readonly TimeSpan HistoryTtl = TimeSpan.FromDays(7);

    private async Task RestoreHistoryFromStorageAsync()
    {
        try
        {
            var tsStr = await JS.InvokeAsync<string?>("localStorage.getItem", HistoryTimestampKey);
            if (tsStr is not null &&
                long.TryParse(tsStr, out var tsUtc) &&
                DateTimeOffset.UtcNow - DateTimeOffset.FromUnixTimeSeconds(tsUtc) < HistoryTtl)
            {
                var json = await JS.InvokeAsync<string?>("localStorage.getItem", HistoryStorageKey);
                if (!string.IsNullOrWhiteSpace(json))
                {
                    var turns = JsonSerializer.Deserialize<List<ConversationTurn>>(json);
                    if (turns is { Count: > 0 })
                    {
                        Orchestrator.RestoreHistory(turns);
                        // Note: we restore LLM context only — we don't rebuild the visible _history
                        // because ChatEntry contains rendered content that is not persisted.
                    }
                }
            }
        }
        catch
        {
            // LocalStorage may be blocked in private/incognito mode — fail silently.
        }
    }

    private async Task SaveHistoryToStorageAsync()
    {
        try
        {
            var turns = Orchestrator.GetHistory();
            if (turns.Count == 0) return;
            var json = JsonSerializer.Serialize(turns);
            var ts   = DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString();
            await JS.InvokeVoidAsync("localStorage.setItem", HistoryStorageKey, json);
            await JS.InvokeVoidAsync("localStorage.setItem", HistoryTimestampKey, ts);
        }
        catch { /* LocalStorage unavailable */ }
    }

    // ── Progress event handler (ME-4) ────────────────────────────────
    private void HandleProgressChanged(string message)
    {
        _progressMessage = message;
        InvokeAsync(StateHasChanged);
    }

    // ── Agent panel helpers ──────────────────────────────────────────
    private void ToggleAgentPanel() => _showAgentPanel = !_showAgentPanel;
    private void EnableAll()  => _enabledIds = _allAgents.Select(a => a.Id).ToHashSet();
    private void DisableAll() => _enabledIds = [];

    private void ToggleAgent(string id, bool enabled)
    {
        if (enabled) _enabledIds.Add(id);
        else         _enabledIds.Remove(id);
    }

    private string ResolveAgentName(string agentId)
    {
        var agent = Registry.FindById(agentId);
        return agent?.Name ?? agentId;
    }

    // ── Clear conversation (QW-2 + LF-3) ────────────────────────────
    private async Task ClearConversation()
    {
        _history.Clear();
        Orchestrator.ClearHistory();
        try
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", HistoryStorageKey);
            await JS.InvokeVoidAsync("localStorage.removeItem", HistoryTimestampKey);
        }
        catch { /* LocalStorage unavailable */ }
        StateHasChanged();
    }

    // ── Stop streaming (QW-1) ────────────────────────────────────────
    private void StopStreaming() => _cts?.Cancel();

    // ── Export conversation (ME-1) ───────────────────────────────────
    private async Task ExportConversationAsync(string format)
    {
        if (_history.Count == 0) return;

        string content;
        string fileName;
        string mimeType;

        if (format == "json")
        {
            var data = _history.Select(e => new
            {
                role      = e.Role.ToString().ToLower(),
                content   = e.Content,
                timestamp = e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss"),
                attachment = e.AttachmentName,
                agentInfo  = e.AgentInfo
            });
            content  = JsonSerializer.Serialize(data, new JsonSerializerOptions { WriteIndented = true });
            fileName = $"conversation-{DateTime.UtcNow:yyyyMMdd-HHmmss}.json";
            mimeType = "application/json";
        }
        else
        {
            var sb = new StringBuilder();
            sb.AppendLine($"# Conversation — {DateTime.UtcNow:yyyy-MM-dd HH:mm} UTC");
            sb.AppendLine();
            foreach (var e in _history)
            {
                sb.AppendLine($"## {e.Role} — {e.Timestamp:HH:mm:ss}");
                if (e.AttachmentName is not null)
                    sb.AppendLine($"*Attachment: {e.AttachmentName}*");
                sb.AppendLine();
                sb.AppendLine(e.Content ?? "");
                if (e.AgentInfo is not null)
                    sb.AppendLine();
                sb.AppendLine();
            }
            content  = sb.ToString();
            fileName = $"conversation-{DateTime.UtcNow:yyyyMMdd-HHmmss}.md";
            mimeType = "text/markdown";
        }

        var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(content));
        await JS.InvokeVoidAsync("BlazorChat.downloadFile", fileName, mimeType, base64);
    }

    // ── File attachment ───────────────────────────────────────────────
    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        const long maxBytes = 10 * 1024 * 1024; // 10 MB limit
        if (file.Size > maxBytes)
        {
            // Show error in chat
            _history.Add(new ChatEntry
            {
                Role    = ChatEntry.ChatRole.Assistant,
                Content = $"File **{file.Name}** is too large ({file.Size / 1024 / 1024} MB). Maximum size is 10 MB."
            });
            StateHasChanged();
            return;
        }

        _isThinking            = true;
        _isAnalyzingAttachment = true;
        _pendingAttachmentName = file.Name;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: maxBytes);
            _processedAttachment = await AttachmentProcessor.ProcessAsync(
                file.Name, file.ContentType, stream);
            _pendingAttachmentName = file.Name; // keep preview showing
        }
        catch (Exception ex)
        {
            _processedAttachment   = null;
            _pendingAttachmentName = null;
            _history.Add(new ChatEntry
            {
                Role    = ChatEntry.ChatRole.Assistant,
                Content = $"Failed to process attachment **{file.Name}**: {ex.Message}"
            });
        }
        finally
        {
            _isThinking            = false;
            _isAnalyzingAttachment = false;
            StateHasChanged();
        }
    }

    private void RemoveAttachment()
    {
        _processedAttachment   = null;
        _pendingAttachmentName = null;
    }

    // ── Copy to clipboard ────────────────────────────────────────────
    private async Task CopyToClipboardAsync(ChatEntry entry)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", entry.Content);
            _copiedId = entry.Id;
            StateHasChanged();
            await Task.Delay(2000);
            _copiedId = null;
            StateHasChanged();
        }
        catch
        {
            // Clipboard API may be unavailable in some browsers/contexts
        }
    }

    // ── Send logic ───────────────────────────────────────────────────
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendAsync();
    }

    private async Task SendAsync()
    {
        var question = _inputText.Trim();
        if (string.IsNullOrEmpty(question) || _isThinking || _enabledIds.Count == 0)
            return;

        _inputText      = string.Empty;
        _isThinking     = true;
        _progressMessage = null;

        // Capture and clear attachment before the async operation
        var attachment             = _processedAttachment;
        var attachmentName         = _pendingAttachmentName;
        _processedAttachment       = null;
        _pendingAttachmentName     = null;

        _history.Add(new ChatEntry
        {
            Role           = ChatEntry.ChatRole.User,
            Content        = question,
            AttachmentName = attachmentName
        });

        var assistantEntry = new ChatEntry { Role = ChatEntry.ChatRole.Assistant };
        _history.Add(assistantEntry);
        _shouldScrollToBottom = true;
        StateHasChanged();

        _cts = new CancellationTokenSource();

        try
        {
            // Pass the current enabled-agent filter and any attachment to the orchestration service
            var enabledSet = (IReadOnlySet<string>)_enabledIds;
            await foreach (var token in Orchestrator.AskAsync(question, _cts.Token, enabledSet, attachment))
            {
                assistantEntry.Content += token;
                _shouldScrollToBottom   = true;
                StateHasChanged();
                await Task.Yield();
            }

            // Set agent disclosure inline — AgentInfo is now mutable (set accessor)
            if (Orchestrator.LastMetadata is { } m && m.SelectedAgents.Count > 0)
            {
                assistantEntry.AgentInfo = "Consulted: " + string.Join(", ",
                    m.SelectedAgents.Select(s =>
                        $"{ResolveAgentName(s.AgentId)} ({s.Confidence:P0})" +
                        (s.Reason is not null ? $" — {s.Reason}" : "")));
            }

            // LF-3: Persist conversation turns to LocalStorage after each successful exchange
            await SaveHistoryToStorageAsync();
        }
        catch (OperationCanceledException)
        {
            assistantEntry.Content += " [cancelled]";
        }
        catch (Exception ex)
        {
            assistantEntry.Content = $"Error: {ex.Message}";
        }
        finally
        {
            _isThinking      = false;
            _progressMessage = null;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Orchestrator.OnProgressChanged -= HandleProgressChanged;
    }
}
