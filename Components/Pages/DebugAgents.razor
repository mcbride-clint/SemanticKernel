@page "/debug"
@using BlazorAgentChat.Abstractions
@using BlazorAgentChat.Abstractions.Models
@inject IAgentRegistry Registry
@inject IOrchestrationService Orchestrator

<PageTitle>Debug Agents</PageTitle>

<h2>Loaded Agents (@Registry.GetAll().Count)</h2>

<table class="debug-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Source</th>
            <th>Description</th>
            <th>Content Size</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Registry.GetAll())
        {
            <tr>
                <td><code>@a.Id</code></td>
                <td>@a.Name</td>
                <td><span class="source-badge source-@a.SourceType">@a.SourceType</span></td>
                <td>@a.Description</td>
                <td>@($"{a.PdfCharCount:N0} chars")</td>
            </tr>
        }
        @if (!Registry.GetAll().Any())
        {
            <tr>
                <td colspan="5"><em>No agents loaded. Check Data/ directory and logs.</em></td>
            </tr>
        }
    </tbody>
</table>

<h2>LLM Connectivity Test</h2>
<button @onclick="PingAsync" disabled="@_pinging">@(_pinging ? "Testing…" : "Ping LLM")</button>

@if (_pingResult is not null)
{
    <pre class="ping-result">@_pingResult</pre>
}

@if (Orchestrator.LastMetadata is { } meta)
{
    <h3>Last Orchestration</h3>
    <pre class="ping-result">
Correlation ID   : @meta.CorrelationId
Total elapsed    : @meta.TotalElapsed.TotalSeconds.ToString("F2")s
  Routing        : @meta.RoutingElapsed.TotalMilliseconds.ToString("F0") ms
  Agent execution: @((meta.TotalElapsed - meta.RoutingElapsed - meta.SynthesisElapsed).TotalMilliseconds.ToString("F0")) ms
  Synthesis      : @meta.SynthesisElapsed.TotalMilliseconds.ToString("F0") ms
    </pre>

    <h3>Agent Routing — Selected Agents</h3>
    <table class="debug-table">
        <thead>
            <tr>
                <th>Agent</th>
                <th>Confidence</th>
                <th>Router Reason</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sel in meta.SelectedAgents)
            {
                var info = Registry.FindById(sel.AgentId);
                <tr>
                    <td>@(info?.Name ?? sel.AgentId)</td>
                    <td>
                        <div class="confidence-bar-wrap">
                            <div class="confidence-bar" style="width:@((sel.Confidence * 100).ToString("F0"))%"></div>
                            <span class="confidence-label">@sel.Confidence.ToString("P0")</span>
                        </div>
                    </td>
                    <td>@(sel.Reason ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>Agent Execution Results</h3>
    <table class="debug-table">
        <thead>
            <tr>
                <th>Agent</th>
                <th>Status</th>
                <th>Elapsed</th>
                <th>Est. Tokens</th>
                <th>Error</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in meta.AgentResults)
            {
                <tr class="@(r.Success ? "" : "agent-run-failed")">
                    <td>@r.AgentName</td>
                    <td>@(r.Success ? "✓ OK" : "✗ Failed")</td>
                    <td>@r.Elapsed.TotalMilliseconds.ToString("F0") ms</td>
                    <td>@(r.EstimatedTokens > 0 ? r.EstimatedTokens.ToString("N0") : "—")</td>
                    <td><small>@(r.ErrorMessage ?? "")</small></td>
                </tr>
            }
            @if (!meta.AgentResults.Any())
            {
                <tr><td colspan="5"><em>No agent results recorded.</em></td></tr>
            }
        </tbody>
    </table>
}

@code {
    private string? _pingResult;
    private bool _pinging;

    private async Task PingAsync()
    {
        _pinging    = true;
        _pingResult = "Testing…";
        StateHasChanged();

        try
        {
            var sb = new System.Text.StringBuilder();
            await foreach (var token in Orchestrator.AskAsync("Say hello in one sentence."))
                sb.Append(token);

            _pingResult = sb.ToString();

            if (Orchestrator.LastMetadata is { } m)
                _pingResult += $"\n\n[Agents: {string.Join(", ", m.SelectedAgentIds)}, " +
                               $"Elapsed: {m.TotalElapsed.TotalSeconds:F2}s, " +
                               $"Id: {m.CorrelationId}]";
        }
        catch (Exception ex)
        {
            _pingResult = $"ERROR: {ex.Message}";
        }
        finally
        {
            _pinging = false;
            StateHasChanged();
        }
    }
}
