<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Agent Chat</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="stylesheet" href="~/app.css" asp-append-version="true" />
    <script>
        // Apply saved theme before first paint to avoid flash
        (function () {
            var t = localStorage.getItem('theme');
            if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
</head>
<body>
    <div class="layout">
        <nav class="sidebar">
            <div class="sidebar-header">
                <span class="sidebar-logo">&#x1F916;</span>
                <span class="sidebar-title">Agent Chat</span>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/" class="nav-link @(ViewData["Page"]?.ToString() == "Chat" ? "active" : "")">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M2 5a2 2 0 012-2h12a2 2 0 012 2v7a2 2 0 01-2 2H6l-4 4V5z"/></svg>
                    Chat
                </a></li>
                <li><a href="/debug" class="nav-link @(ViewData["Page"]?.ToString() == "Debug" ? "active" : "")">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M11 2a1 1 0 10-2 0v1H7a1 1 0 00-.894.553L5.382 5H4a2 2 0 00-2 2v1a2 2 0 002 2h.01l.25 3H2a1 1 0 000 2h.438l.5 2H2a1 1 0 100 2h16a1 1 0 100-2h-.938l.5-2H18a1 1 0 000-2h-2.26l.25-3H16a2 2 0 002-2V7a2 2 0 00-2-2h-1.382l-.724-1.447A1 1 0 0011 3V2z" clip-rule="evenodd"/></svg>
                    Debug
                </a></li>
            </ul>
            <div class="sidebar-footer">
                <button id="theme-toggle" class="theme-btn" title="Toggle dark mode" onclick="toggleTheme()">
                    <span class="theme-icon-light">&#9728;</span>
                    <span class="theme-icon-dark">&#9790;</span>
                </button>
            </div>
        </nav>
        <main class="main-content">
            @RenderBody()
        </main>
    </div>
    <script>
        function toggleTheme() {
            var html = document.documentElement;
            html.classList.toggle('dark');
            localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
        }
    </script>
</body>
</html>
