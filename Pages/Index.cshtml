@page
@model IndexModel
@{
    ViewData["Title"] = "Chat";
    ViewData["Page"] = "Chat";
    var agentsByType = Model.Agents.GroupBy(a => a.SourceType).OrderBy(g => g.Key).ToList();
}

<div class="chat-page">
    <!-- Agent selection panel -->
    <div class="agent-sidebar">
        <div class="agent-sidebar-header">
            <button class="agent-toggle-btn" id="agent-toggle-btn" onclick="AgentPanel.toggle()">
                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM2 8a2 2 0 114 0A2 2 0 012 8zm.992 3H2A2 2 0 000 13v2h5.992A5.96 5.96 0 005 13a6.008 6.008 0 01.996-3.328A2.001 2.001 0 002.992 11zM14 11h.008A2.001 2.001 0 0115 9.672 6.008 6.008 0 0115 13a5.96 5.96 0 00-.992 2H20v-2a2 2 0 00-2-2h-.008zM7 13a4 4 0 108 0 4 4 0 00-8 0z"/></svg>
                <span id="agent-toggle-label">Agents (<span id="enabled-count">@Model.Agents.Count</span>/<span id="total-count">@Model.Agents.Count</span>)</span>
                <svg class="chevron" viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
        </div>
        <div class="agent-panel" id="agent-panel">
            <div class="agent-panel-actions">
                <button class="btn-xs" onclick="AgentPanel.enableAll()">All</button>
                <button class="btn-xs" onclick="AgentPanel.disableAll()">None</button>
                <input type="text" id="agent-search" class="agent-search" placeholder="Search agents…" oninput="AgentPanel.filter(this.value)" @(Model.Agents.Count <= 5 ? "style=\"display:none\"" : "") />
            </div>
            <div id="agent-list">
                @foreach (var group in agentsByType)
                {
                    <div class="agent-group" data-type="@group.Key">
                        <div class="agent-group-label">
                            <span class="agent-type-badge agent-type-@group.Key">@group.Key</span>
                        </div>
                        @foreach (var agent in group)
                        {
                            <label class="agent-row" data-agent-id="@agent.Id">
                                <input type="checkbox" class="agent-checkbox" value="@agent.Id" checked
                                       onchange="AgentPanel.toggle('@agent.Id', this.checked)" />
                                <span class="agent-row-text">
                                    <span class="agent-row-name">@agent.Name</span>
                                    <span class="agent-row-desc">@agent.Description</span>
                                </span>
                            </label>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Chat area -->
    <div class="chat-container">
        <div class="chat-history" id="chat-history"></div>

        <!-- Attachment preview -->
        <div id="attachment-preview" class="attachment-preview" style="display:none">
            <img id="attachment-thumbnail" class="attachment-thumbnail" src="" alt="" style="display:none" />
            <span class="attachment-icon" id="attachment-icon" style="display:none">&#128206;</span>
            <span id="attachment-filename" class="attachment-filename"></span>
            <button class="attachment-remove" onclick="Attachment.clear()" title="Remove attachment">&times;</button>
        </div>

        <!-- Input area -->
        <div class="chat-input-area">
            <label class="attach-btn" title="Attach file" for="file-input">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 11-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd"/></svg>
            </label>
            <input type="file" id="file-input" style="display:none"
                   accept=".pdf,.txt,.csv,.md,.png,.jpg,.jpeg,.gif,.webp"
                   onchange="Attachment.upload(this)" />
            <textarea id="chat-input" class="chat-input" rows="1"
                      placeholder="Ask a question…"
                      onkeydown="Chat.handleKey(event)"
                      oninput="Chat.autoResize(this)"></textarea>
            <button id="send-btn" class="send-btn" onclick="Chat.send()">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>
                Send
            </button>
            <button id="stop-btn" class="stop-btn" onclick="Chat.stop()" style="display:none">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8 7a1 1 0 00-1 1v4a1 1 0 001 1h4a1 1 0 001-1V8a1 1 0 00-1-1H8z" clip-rule="evenodd"/></svg>
                Stop
            </button>
            <button class="export-btn btn-xs" onclick="Chat.exportHistory()" title="Export conversation">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
            <button class="clear-btn btn-xs" onclick="Chat.clearHistory()" title="Clear conversation">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            </button>
        </div>
    </div>
</div>

<!-- Embed agent data for JS bootstrap -->
<script id="agent-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => new { a.Id, a.Name, a.Description, a.SourceType })))
</script>

<script src="~/js/marked.min.js" asp-append-version="true"></script>
<script src="~/js/chat.js" asp-append-version="true"></script>
